{
  "name": "monitor-amb-desktop",
  "version": "1.0.0",
  "description": "Monitor Amb — Painel de Chamadas do Ambulatório IECAC",
  "author": "Diogo Aleixo de Andrade",
  "private": true,
  "main": "src/main/main.js",
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0 --port 5173",
    "dev:electron": "concurrently \"npm:dev\" \"wait-on http://127.0.0.1:5173 && cross-env NODE_ENV=development electron .\"",
    "build": "vite build",
    "preview": "vite preview --host 0.0.0.0 --port 4173"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "react": "latest",
    "react-dom": "latest",
    "react-router-dom": "latest"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "latest",
    "concurrently": "latest",
    "cross-env": "latest",
    "electron": "latest",
    "vite": "latest",
    "wait-on": "latest"
  }
}
